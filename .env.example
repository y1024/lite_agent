# .env.example
# -----------------------------
# Lite Agent Environment Config
# -----------------------------

# Server Port (optional, default 8000)
PORT=8000

# OCR Endpoint (For PaddleOCR-VL Multi-modal image parsing)
OCR_ENDPOINT=http://100.103.70.97:8000/api/ocr
# -----------------------------

# LLM API Keys
DEEPSEEK_API_KEY=sk-your-key
GEMINI_API_KEY=AIza-your-key

# Channel Secrets
FEISHU_APP_SECRET=your-feishu-app-secret
TG_BOT_TOKEN=your-tg-bot-token
DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret
WECOM_PUSH_TOKEN=your-wecom-push-token
API_AUTH_TOKEN=your-api-auth-token

# Database & External Services
RSSDB_URI=mongodb://user:pass@localhost:27017
V2EX_TOKEN=your-v2ex-token
HALO_PASSWORD=your-halo-password
POSTGRES_PASSWORD=your-postgres-password
