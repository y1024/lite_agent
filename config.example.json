{
    "bot_name": "VPS 助手",
    "llm": {
        "base_url": "https://api.deepseek.com/v1",
        "api_key": "${DEEPSEEK_API_KEY}",
        "model": "deepseek-v4-flash",
        "max_tokens": 2048,
        "temperature": 0.3,
        "models": {
            "flash": {
                "base_url": "https://api.deepseek.com/v1",
                "api_key": "${DEEPSEEK_API_KEY}",
                "model": "deepseek-v4-flash",
                "max_tokens": 2048,
                "max_steps": 30,
                "tags": [
                    "text",
                    "fast"
                ]
            },
            "gemini-flash": {
                "api_key": "${GEMINI_API_KEY}",
                "model": "gemini-2.5-flash",
                "max_tokens": 8192,
                "temperature": 0.3,
                "max_steps": 30,
                "proxy": "socks5://127.0.0.1:18988",
                "tags": [
                    "gemini",
                    "text",
                    "fast"
                ]
            },
            "gemini-pro": {
                "api_key": "${GEMINI_API_KEY}",
                "model": "gemini-2.5-flash",
                "max_tokens": 8192,
                "temperature": 0.1,
                "max_steps": 30,
                "proxy": "socks5://127.0.0.1:18988",
                "tags": [
                    "gemini",
                    "code",
                    "complex_reasoning"
                ]
            }
        },
        "default": "flash"
    },
    "session": {
        "ttl_minutes": 30,
        "max_history": 20,
        "max_history_bytes": 40000,
        "max_steps_per_goal": 30,
        "daily_token_limit": 500000
    },
    "security": {
        "allowed_users": [],
        "sandbox_paths": [
            "/var/log",
            "/root/down",
            "/root/script",
            "/root/cert",
            "/root/alert",
            "/root/mail-statement-parser"
        ],
        "blocked_commands": [
            "rm -rf /",
            "mkfs",
            "dd if=",
            "> /dev/sd",
            "shutdown",
            "reboot",
            "passwd"
        ]
    },
    "channels": {
        "feishu": {
            "enabled": true,
            "app_id": "cli_a9439c9bcaf8dcd4",
            "app_secret": "${FEISHU_APP_SECRET}",
            "admin_open_id": "ou_7135c531f7a77b6cb3ae8b27e5dc056b"
        },
        "telegram": {
            "enabled": true,
            "bot_token": "${TG_BOT_TOKEN}",
            "proxy": "socks5h://127.0.0.1:18988",
            "admin_chat_id": "7797851184"
        },
        "dingtalk": {
            "enabled": true,
            "client_id": "dingb2eadjfacycy1kuk",
            "client_secret": "${DINGTALK_CLIENT_SECRET}",
            "admin_staff_id": "manager123"
        },
        "wecom": {
            "enabled": true,
            "push_url": "http://127.0.0.1:6969/send_message",
            "push_token": "${WECOM_PUSH_TOKEN}",
            "listen_port": 8899
        },
        "api": {
            "enabled": true,
            "host": "0.0.0.0",
            "port": 8887,
            "auth_token": "${API_AUTH_TOKEN}",
            "guest_token": "guest_123456"
        }
    },
    "rssdb": {
        "uri": "${RSSDB_URI}",
        "database": "rsslite"
    },
    "v2ex": {
        "token": "${V2EX_TOKEN}"
    },
    "project_root": "/root/lite_agent",
    "cron_jobs": [
        {
            "name": "证书过期检查",
            "time": "09:00",
            "command": "bash /root/down/check_cert_expiry.sh"
        },
        {
            "_comment": "记忆蒸馏复盘 已迁移至 lite-agent 主进程后台线程 (memory_engine.lite_integration.start_distill_scheduler) - 启动 5 分钟后跑首次，之后每 24h 一次。这里 03:00 cron 因 ops_memory_distiller.py 读 LLM_API_KEY env 拿不到，会降级为规则蒸馏并提前消化未蒸馏消息，破坏后台 LLM 蒸馏数据源。删除避免冲突。"
        },
        {
            "name": "系统状态巡检",
            "time": "08:00",
            "command": "python3 -c \"import sys; sys.path.insert(0,'{root}'); from skills.ops_sys import ops_sys_status; print(ops_sys_status(detail=True))\""
        },
        {
            "name": "RSS 预计算",
            "time_range": {
                "start": 9,
                "end": 22,
                "minute": 50
            },
            "skill": "ops_rss::rss_precompute"
        },
        {
            "name": "RSS 精选推送",
            "time_range": {
                "start": 9,
                "end": 22,
                "minute": 3
            },
            "skill": "ops_rss::rss_push"
        },
        {
            "name": "每日健康巡检广播",
            "time": "23:50",
            "skill": "ops_self_check::daily_health"
        }
    ],
    "service_name": "lite-agent",
    "task_routing": {
        "planner_model": "flash",
        "classifier_model": "flash",
        "route_rules": [
            {
                "type": "text",
                "model": "gemini-flash",
                "fallback": "flash"
            },
            {
                "type": "code",
                "model": "pro",
                "fallback": "flash",
                "tools": [
                    "ops_workspace_run"
                ]
            },
            {
                "type": "complex_reasoning",
                "model": "gemini-pro",
                "fallback": "pro"
            },
            {
                "type": "data_analysis",
                "model": "pro",
                "fallback": "flash",
                "tools": [
                    "ops_billing_cost",
                    "ops_logs_query",
                    "ops_sys_status",
                    "ops_workspace_run",
                    "ops_web_fetch"
                ]
            }
        ],
        "max_parallel_subtasks": 3,
        "subtask_timeout_minutes": 15,
        "dag_max_depth": 5,
        "dag_max_total_steps": 30,
        "dag_max_total_tokens": 200000
    },
    "halo": {
        "url": "http://127.0.0.1:8090",
        "username": "admin",
        "password": "${HALO_PASSWORD}"
    },
    "media": {
        "postgres_host": "100.115.42.126",
        "postgres_port": 5432,
        "postgres_user": "postgres",
        "postgres_password": "${POSTGRES_PASSWORD}",
        "postgres_db": "webmusic"
    },
    "hedgedoc": {
        "enabled": true,
        "internal_url": "http://127.0.0.1:3030",
        "public_url": "https://md.maifeipin.com",
        "email": "liteagent@bot.com",
        "password": "${HEDGEDOC_PASSWORD}"
    },
    "committee": {
        "models": [
            "gemini-pro",
            "flash"
        ],
        "task_profiles": {
            "price_comparison": {
                "base_weights": {
                    "profitability": 0.35,
                    "execution": 0.2,
                    "timeliness": 0.15,
                    "confidence": 0.1
                },
                "extra_criteria": [
                    {
                        "name": "supply_demand_balance",
                        "weight": 0.2,
                        "description": "判断市场供需关系、出手速度和库存风险"
                    }
                ],
                "description": "用于评估闲鱼二手比价和套利空间的决策"
            },
            "trend_analysis": {
                "base_weights": {
                    "profitability": 0.1,
                    "execution": 0.4,
                    "timeliness": 0.4,
                    "confidence": 0.1
                },
                "extra_criteria": [
                    {
                        "name": "virality_potential",
                        "weight": 0.2,
                        "description": "评估该趋势在小红书、抖音、YouTube上的传播势能"
                    }
                ],
                "description": "用于评估短视频趋势、社交媒体热点是否值得跟进"
            }
        }
    }
}