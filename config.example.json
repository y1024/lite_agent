{
    "bot_name": "VPS 助手",
    "project_root": "/root/lite_agent",
    "service_name": "lite-agent",
    "llm": {
        "base_url": "https://api.deepseek.com/v1",
        "api_key": "sk-YOUR_API_KEY_HERE",
        "model": "deepseek-v4-flash",
        "max_tokens": 2048,
        "temperature": 0.3,
        "default": "flash",
        "models": {
            "flash": {
                "base_url": "https://api.deepseek.com/v1",
                "api_key": "sk-YOUR_API_KEY_HERE",
                "model": "deepseek-v4-flash",
                "max_tokens": 2048,
                "temperature": 0.3,
                "max_steps": 8,
                "tags": [
                    "text",
                    "fast"
                ]
            },
            "pro": {
                "base_url": "https://api.deepseek.com/v1",
                "api_key": "sk-YOUR_API_KEY_HERE",
                "model": "deepseek-v4-pro",
                "max_tokens": 8192,
                "temperature": 0.1,
                "max_steps": 12,
                "tags": [
                    "code",
                    "complex_reasoning",
                    "data_analysis"
                ]
            },
            "vision": {
                "base_url": "https://api.openai.com/v1",
                "api_key": "sk-YOUR_OPENAI_KEY",
                "model": "gpt-4o",
                "max_tokens": 4096,
                "temperature": 0.3,
                "max_steps": 10,
                "tags": [
                    "multimodal",
                    "vision",
                    "code"
                ]
            },
            "gemini-flash": {
                "api_key": "YOUR_GEMINI_API_KEY",
                "model": "gemini-3.5-flash",
                "max_tokens": 8192,
                "temperature": 0.3,
                "max_steps": 8,
                "proxy": "",
                "tags": [
                    "gemini",
                    "text",
                    "fast"
                ]
            },
            "gemini-pro": {
                "api_key": "YOUR_GEMINI_API_KEY",
                "model": "gemini-2.0-flash",
                "max_tokens": 8192,
                "temperature": 0.1,
                "max_steps": 12,
                "proxy": "",
                "tags": [
                    "gemini",
                    "code",
                    "complex_reasoning"
                ]
            }
        }
    },
    "session": {
        "ttl_minutes": 30,
        "max_history": 20,
        "max_steps_per_goal": 10,
        "daily_token_limit": 500000
    },
    "task_routing": {
        "planner_model": "pro",
        "classifier_model": "flash",
        "route_rules": [
            {
                "type": "text",
                "model": "flash",
                "fallback": "gemini-flash"
            },
            {
                "type": "code",
                "model": "pro",
                "fallback": "flash",
                "tools": [
                    "ops_workspace"
                ]
            },
            {
                "type": "multimodal",
                "model": "vision",
                "fallback": "pro"
            },
            {
                "type": "complex_reasoning",
                "model": "pro",
                "fallback": "gemini-pro"
            },
            {
                "type": "data_analysis",
                "model": "pro",
                "fallback": "flash",
                "tools": [
                    "ops_billing",
                    "ops_logs",
                    "ops_sys",
                    "ops_workspace"
                ]
            }
        ],
        "max_parallel_subtasks": 3,
        "subtask_timeout_minutes": 15,
        "dag_max_depth": 5
    },
    "security": {
        "allowed_users": [],
        "sandbox_paths": [
            "/var/log",
            "/root/down",
            "/root/script"
        ],
        "blocked_commands": [
            "rm -rf /",
            "mkfs",
            "dd if=",
            "> /dev/sd",
            "shutdown",
            "reboot",
            "passwd"
        ]
    },
    "rssdb": {
        "uri": "mongodb://user:pass@localhost:27017",
        "database": "rsslite"
    },
    "v2ex": {
        "token": "YOUR_V2EX_TOKEN"
    },
    "cron_jobs": [
        {
            "name": "证书过期检查",
            "time": "09:00",
            "command": "bash /root/down/check_cert_expiry.sh"
        },
        {
            "name": "记忆蒸馏复盘",
            "time": "03:00",
            "command": "python3 {root}/skills/ops_memory_distiller.py --mode daily"
        },
        {
            "name": "系统状态巡检",
            "time": "08:00",
            "command": "python3 -c \"import sys; sys.path.insert(0,'{root}'); from skills.ops_sys import ops_sys_status; print(ops_sys_status(detail=True))\""
        },
        {
            "name": "RSS 预计算",
            "time_range": {
                "start": 9,
                "end": 22,
                "minute": 50
            },
            "skill": "ops_rss::rss_precompute"
        },
        {
            "name": "RSS 精选推送",
            "time_range": {
                "start": 9,
                "end": 22,
                "minute": 3
            },
            "skill": "ops_rss::rss_push"
        },
        {
            "name": "每日健康巡检广播",
            "time": "23:50",
            "skill": "ops_self_check::daily_health"
        }
    ],
    "channels": {
        "feishu": {
            "enabled": true,
            "app_id": "cli_xxxxxxxx",
            "app_secret": "xxxxxxxx",
            "admin_open_id": "ou_xxxxxxxx"
        },
        "telegram": {
            "enabled": false,
            "bot_token": "YOUR_TG_BOT_TOKEN",
            "proxy": "http://127.0.0.1:7890",
            "admin_chat_id": "YOUR_CHAT_ID"
        },
        "dingtalk": {
            "enabled": false,
            "client_id": "YOUR_DINGTALK_CLIENT_ID",
            "client_secret": "YOUR_DINGTALK_CLIENT_SECRET"
        },
        "wecom": {
            "enabled": false,
            "listen_port": 8899,
            "push_url": "http://127.0.0.1:6969/send_message",
            "push_token": "YOUR_PUSHMSG_TOKEN"
        },
        "api": {
            "enabled": false,
            "host": "0.0.0.0",
            "port": 8887,
            "auth_token": "your_secret_token_here",
            "guest_token": "your_guest_token_here"
        }
    },
    "halo": {
        "url": "http://127.0.0.1:8090",
        "username": "admin",
        "password": "YOUR_PASSWORD"
    }
}